proxmox_endpoint  = "https://10.2.0.30:8006"
proxmox_api_token = "root@pam!k3s-token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure  = true
proxmox_ssh_user  = "root"
proxmox_node      = "pve"

template_vmid  = 9000   # your Ubuntu 22.04 cloud-init template
storage_pool   = "xpg_nvme"
network_bridge = "vmbr0"
vlan_id = 200

server_count = 3
agent_count  = 3

server_vmid_start = 200
agent_vmid_start  = 210

node_cidr       = "10.2.0.0/24"
node_prefix     = 24
server_ip_start = 70   # → .10 .11 .12
agent_ip_start  = 80   # → .20 .21 .22
gateway         = "10.2.0.1"
dns_server      = "10.2.0.7"   # Pi-hole LXC

server_cores     = 2
server_memory    = 4096
server_disk_size = 20

agent_cores     = 2
agent_memory    = 4096
agent_disk_size = 30

vm_user        = "ubuntu"
ssh_public_key = "/root/.ssh/lan_key.pub"
